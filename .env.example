## Langchain
LANGCHAIN_API_KEY='lsv2_pt_* langsmith-API-key'
LANGSMITH_API_KEY='lsv2_pt_* langsmith-API-key (the same)'
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true

## tavily or any other API key
TAVILY_API_KEY='tvly-dev-* tavily-API-key'

# Model providers
## Openrouter
OPENROUTER_API_KEY='sk-or-v1-* openrouter-API-key'
OPENROUTER_BASE_URL='https://openrouter.ai/api/v1'

## Openai
OPENAI_API_KEY='no need'
OPENAI_BASE_URL=''

## Groq
GROQ_API_KEY='gsk_* groq-API-key'
GROQ_BASE_URL='https://api.groq.com/openai/v1'

# Other Variables
DEBUG=1

# To change whenever model change needed
# You should have {PROVIDER}_API_KEY and {PROVIDER}_BASE_URL
PROVIDER='OPENROUTER'
MODEL_NAME='stepfun/step-3.5-flash:free' # Or any model provided under by the PROVIDER